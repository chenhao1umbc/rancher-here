# Custom dircolors for better readability in Claude Code container
# Optimized for dark terminal backgrounds

# File types
NORMAL 00        # no color code
FILE 00          # regular file
RESET 0          # reset to normal color
DIR 01;34        # directory (bright blue)
LINK 01;36       # symbolic link (bright cyan)
MULTIHARDLINK 00 # regular file with more than one link
FIFO 40;33       # pipe (yellow bg)
SOCK 01;35       # socket (bright magenta)
DOOR 01;35       # door
BLK 40;33;01     # block device driver (yellow bg, bright)
CHR 40;33;01     # character device driver (yellow bg, bright)
ORPHAN 40;31;01  # orphaned symlink (red bg, bright)
MISSING 00       # missing file
SETUID 37;41     # file with setuid (white fg, red bg)
SETGID 30;43     # file with setgid (black fg, yellow bg)
CAPABILITY 30;41 # file with capability
STICKY_OTHER_WRITABLE 30;42 # dir that is sticky and other-writable (black fg, green bg)
OTHER_WRITABLE 34;42 # dir that is other-writable (blue fg, green bg)
STICKY 37;44     # dir with sticky bit (white fg, blue bg)
EXEC 01;32       # executable file (bright green)

